<html>
<body style="font-family:sans-serif;padding:40px">

<h1>🧭 LifeGuide AI</h1>

<input id="q" placeholder="輸入問題"/>
<button onclick="askAI()">詢問</button>

<div id="answer"></div>

<script>
const SAVE_URL = "https://YOUR-WORKER.workers.dev/save";

async function saveDecision(q,a){
  await fetch(SAVE_URL,{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({
      question:q,
      answer:a,
      time:new Date().toISOString()
    })
  });
}

async function askAI(){
  const q=document.getElementById("q").value;
  const answer="LifeGuide 分析："+q;
  document.getElementById("answer").innerText=answer;
  await saveDecision(q,answer);
}
</script>

</body><script>
async function saveMemory(q) {
  await fetch("https://lifeguide-ai.lin0901210103.workers.dev/save", {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify({
      question: q,
      time: Date.now()
    })
  });
}

document.addEventListener("submit", e => {
  const input = document.querySelector("#q");
  if (input) {
    saveMemory(input.value);
  }
});
</script>
</html>


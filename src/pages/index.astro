<html>
<body style="font-family:sans-serif;padding:40px">

<h1>🧭 LifeGuide AI</h1>

<input id="q" placeholder="輸入問題"/>
<button onclick="askAI()">詢問</button>

<div id="answer"></div>

<script>
const SAVE_URL = "https://YOUR-WORKER.workers.dev/save";

async function saveDecision(q,a){
  await fetch(SAVE_URL,{
    method:"POST",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({
      question:q,
      answer:a,
      time:new Date().toISOString()
    })
  });
}

async function askAI(){
  const q=document.getElementById("q").value;
  const answer="LifeGuide 分析："+q;
  document.getElementById("answer").innerText=answer;
  await saveDecision(q,answer);
}
</script>

</body>
</html>

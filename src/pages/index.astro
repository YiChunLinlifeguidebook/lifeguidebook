<html>
<body style="font-family:sans-serif;padding:40px">

<h1>🧭 LifeGuide AI</h1>

<input id="q" placeholder="輸入問題"/>
<button onclick="askAI()">詢問</button>

<div id="answer"></div>

<script>
let isLoading = false;

async function askAI(){
  if (isLoading) return;

  const input = document.getElementById("q");
  const answerEl = document.getElementById("answer");
  const btn = document.querySelector("button");
  const q = input.value.trim();

  if (!q) return;

  isLoading = true;
  btn.disabled = true;
  answerEl.innerText = "思考中…";

  try {
    const resp = await fetch("/api/chat", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ prompt: q }),
    });

    if (!resp.ok) {
      const err = await resp.json().catch(() => ({}));
      answerEl.innerText = "錯誤：" + (err.error || resp.statusText || `HTTP ${resp.status}`);
      return;
    }

    const data = await resp.json();
    const message = data?.choices?.[0]?.message?.content ?? "無法解析回應，請稍後再試。";
    answerEl.innerText = message;
  } catch (e) {
    answerEl.innerText = "請求失敗，請稍後再試。";
  } finally {
    isLoading = false;
    btn.disabled = false;
  }
}
</script>

</body>
</html>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<style>
		.ai-section {
			padding: 2em 1em;
			max-width: 720px;
			margin: 0 auto;
		}
		input {
			padding: 0.5em;
			font-size: 1em;
			width: 70%;
			margin-right: 0.5em;
		}
		button {
			padding: 0.5em 1em;
			font-size: 1em;
			cursor: pointer;
		}
		#answer {
			margin-top: 1em;
			font-size: 1.1em;
		}
	</style>
	<div class="ai-section">
		<h1>🧭 LifeGuide AI</h1>
		<input id="q" placeholder="輸入問題" />
		<button onclick="askAI()">詢問</button>
		<div id="answer"></div>
	</div>
	<script>
		const SAVE_URL = "https://YOUR-WORKER.workers.dev/save";

		async function saveDecision(q: string, a: string) {
			await fetch(SAVE_URL, {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify({
					question: q,
					answer: a,
					time: new Date().toISOString()
				})
			});
		}

		async function askAI() {
			const input = document.getElementById("q") as HTMLInputElement;
			const q = input.value;
			const answer = "LifeGuide 分析：" + q;
			document.getElementById("answer")!.innerText = answer;
			await saveDecision(q, answer);
		}

		(window as any).askAI = askAI;
	</script>
</BaseLayout>

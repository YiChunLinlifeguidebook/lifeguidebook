---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title="AI 串流工作室" description="與 LifeGuide AI 即時串流對話" />
		<style>
			main {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 2em 1em;
				display: flex;
				flex-direction: column;
				gap: 1em;
			}
			h1 {
				font-size: 1.8em;
				margin-bottom: 0.25em;
			}
			.subtitle {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin-bottom: 1em;
			}
			#chat-box {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 1em;
				min-height: 300px;
				max-height: 500px;
				overflow-y: auto;
				background: #fff;
				display: flex;
				flex-direction: column;
				gap: 0.75em;
			}
			.msg {
				padding: 0.6em 0.9em;
				border-radius: 8px;
				line-height: 1.5;
				font-size: 0.95em;
				max-width: 85%;
				white-space: pre-wrap;
				word-break: break-word;
			}
			.msg.user {
				background: var(--accent);
				color: #fff;
				align-self: flex-end;
			}
			.msg.ai {
				background: rgb(var(--gray-light));
				color: rgb(var(--gray-dark));
				align-self: flex-start;
			}
			.msg.ai.streaming::after {
				content: "▋";
				animation: blink 0.7s step-end infinite;
			}
			@keyframes blink {
				50% { opacity: 0; }
			}
			.input-row {
				display: flex;
				gap: 0.5em;
			}
			#prompt-input {
				flex: 1;
				padding: 0.6em 0.8em;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				font-size: 1em;
				font-family: inherit;
				resize: none;
				outline: none;
			}
			#prompt-input:focus {
				border-color: var(--accent);
			}
			#send-btn {
				padding: 0.6em 1.2em;
				background: var(--accent);
				color: #fff;
				border: none;
				border-radius: 8px;
				font-size: 1em;
				cursor: pointer;
				white-space: nowrap;
			}
			#send-btn:disabled {
				opacity: 0.5;
				cursor: not-allowed;
			}
			.empty-hint {
				color: rgb(var(--gray));
				font-size: 0.9em;
				text-align: center;
				margin: auto;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>🤖 AI 串流工作室</h1>
			<p class="subtitle">與 LifeGuide AI 即時對話，回應將以串流方式逐字顯示。</p>
			<div id="chat-box">
				<p class="empty-hint">輸入訊息開始對話 ✨</p>
			</div>
			<div class="input-row">
				<textarea
					id="prompt-input"
					rows="2"
					placeholder="輸入你的問題或想法…"
				></textarea>
				<button id="send-btn">送出</button>
			</div>
		</main>
		<Footer />

		<script>
			const chatBox = document.getElementById('chat-box');
			const promptInput = document.getElementById('prompt-input');
			const sendBtn = document.getElementById('send-btn');

			function appendMessage(role, text, streaming = false) {
				// Remove empty hint on first message
				const hint = chatBox.querySelector('.empty-hint');
				if (hint) hint.remove();

				const div = document.createElement('div');
				div.className = `msg ${role}${streaming ? ' streaming' : ''}`;
				div.textContent = text;
				chatBox.appendChild(div);
				chatBox.scrollTop = chatBox.scrollHeight;
				return div;
			}

			async function sendMessage() {
				const prompt = promptInput.value.trim();
				if (!prompt) return;

				promptInput.value = '';
				sendBtn.disabled = true;

				appendMessage('user', prompt);
				const aiDiv = appendMessage('ai', '', true);

				try {
					const response = await fetch('/api/chat', {
						method: 'POST',
						headers: { 'Content-Type': 'application/json' },
						body: JSON.stringify({ prompt }),
					});

					if (!response.ok) {
						aiDiv.textContent = '⚠️ 伺服器錯誤，請稍後再試。';
						aiDiv.classList.remove('streaming');
						return;
					}

					const reader = response.body.getReader();
					const decoder = new TextDecoder();
					let buffer = '';
					let aiText = '';

					while (true) {
						const { done, value } = await reader.read();
						if (done) break;

						buffer += decoder.decode(value, { stream: true });
						const lines = buffer.split('\n');
						buffer = lines.pop() || ''; // keep incomplete last line

						for (const line of lines) {
							if (!line.startsWith('data: ')) continue;
							const data = line.slice(6).trim();
							if (data === '[DONE]') break;
							try {
								const parsed = JSON.parse(data);
								const delta = parsed.choices?.[0]?.delta?.content;
								if (delta) {
									aiText += delta;
									aiDiv.textContent = aiText;
									chatBox.scrollTop = chatBox.scrollHeight;
								}
							} catch {
								// ignore parse errors for partial chunks
							}
						}
					}
				} catch (err) {
					aiDiv.textContent = '⚠️ 連線失敗，請確認網路後再試。';
				} finally {
					aiDiv.classList.remove('streaming');
					sendBtn.disabled = false;
					promptInput.focus();
				}
			}

			sendBtn.addEventListener('click', sendMessage);
			promptInput.addEventListener('keydown', (e) => {
				if (e.key === 'Enter' && !e.shiftKey) {
					e.preventDefault();
					sendMessage();
				}
			});
		</script>
	</body>
</html>

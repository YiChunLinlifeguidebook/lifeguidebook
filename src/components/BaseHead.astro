---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, image = '/blog-placeholder-1.jpg' } = Astro.props;

// Prepare common meta tag data
const imageUrl = new URL(image, Astro.url);
const pageUrl = Astro.url;

// Define meta tags that are duplicated across Open Graph and Twitter
const socialMetaTags = [
  { property: 'og:type', content: 'website' },
  { property: 'og:url', content: pageUrl },
  { property: 'og:title', content: title },
  { property: 'og:description', content: description },
  { property: 'og:image', content: imageUrl },
  { property: 'twitter:card', content: 'summary_large_image' },
  { property: 'twitter:url', content: pageUrl },
  { property: 'twitter:title', content: title },
  { property: 'twitter:description', content: description },
  { property: 'twitter:image', content: imageUrl },
];
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<meta name="generator" content={Astro.generator} />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook & Twitter -->
{socialMetaTags.map(tag => (
	<meta property={tag.property} content={tag.content} />
))}
